@page
@using MoneroShameList.Helpers
@using MoneroShameList.Models
@model IndexModel
@{
    ViewData["Title"] = "The Monero Shame List";
}

<div class="hero">
    <div class="hero-logo-wrap">
        <img src="/images/monero-symbol-on-white-480.png" alt="Monero" class="hero-logo" />
    </div>
    <h1>The <span>Privacy Hypocrite</span> Shame List</h1>
    <p>Companies that market themselves as privacy-focused but refuse to accept Monero — the only truly private money.</p>
    <a href="/Submit" class="btn btn-primary">Submit a Company</a>
</div>

<div class="index-tabs">
    <a href="?tab=shame&sort=@Model.Sort" class="index-tab @(Model.Tab == "shame" ? "active" : "")">
        Shame List <span class="tab-count">@Model.Entries.Count</span>
    </a>
    <a href="?tab=mixed&sort=@Model.Sort" class="index-tab index-tab-mixed @(Model.Tab == "mixed" ? "active" : "")">
        Mixed Support <span class="tab-count">@Model.MixedSupport.Count</span>
    </a>
    <a href="?tab=converted&sort=@Model.Sort" class="index-tab index-tab-converted @(Model.Tab == "converted" ? "active" : "")">
        Converted ✅ <span class="tab-count">@Model.Converted.Count</span>
    </a>
</div>

<div class="sort-bar">
    <span>Sort by:</span>
    <a href="?tab=@Model.Tab&sort=date" class="@(Model.Sort == "date" ? "active" : "")">Date Added</a>
    <a href="?tab=@Model.Tab&sort=name" class="@(Model.Sort == "name" ? "active" : "")">Name (A–Z)</a>
</div>

@if (Model.Tab == "shame")
{
    @await Html.PartialAsync("_EntryList", Model.Entries)
}
else if (Model.Tab == "mixed")
{
    <p class="tab-description">These companies have partial or unofficial Monero support — they accept it through a third party or don't promote it openly.</p>
    @await Html.PartialAsync("_EntryList", Model.MixedSupport)
}
else
{
    <p class="tab-description">These companies were on the shame list and have since added proper Monero support.</p>
    @if (Model.Converted.Count == 0)
    {
        <div class="empty-state">
            <div class="big-icon">⏳</div>
            <p>None yet. Keep the pressure on.</p>
        </div>
    }
    else
    {
        <div class="shame-list">
            @foreach (var e in Model.Converted)
            {
                <div class="shame-card shame-card-converted">
                    <div class="shame-card-header">
                        <div>
                            <div class="company-name">
                                <a href="/company/@e.Slug" style="color:var(--text);text-decoration:none">@e.Name</a>
                            </div>
                            <a href="@e.Website" target="_blank" rel="noopener nofollow" class="company-website">@e.Website</a>
                        </div>
                        <span class="shame-badge shame-badge-converted">Now Accepts XMR</span>
                    </div>
                    <div class="shame-description">@TextHelpers.Linkify(e.Description)</div>
                    @if (!string.IsNullOrWhiteSpace(e.AdminComment))
                    {
                        <div class="admin-comment"><strong>📌 Note:</strong> @TextHelpers.Linkify(e.AdminComment)</div>
                    }
                    <div class="shame-card-footer">
                        <span></span>
                        <span class="date-added">Added @e.DateAdded.ToString("MMM d, yyyy")</span>
                    </div>
                </div>
            }
        </div>
    }
}