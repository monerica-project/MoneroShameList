@page
@using MoneroShameList.Helpers
@using MoneroShameList.Models
@model IndexModel
@{
    ViewData["Title"] = "The Monero Shame List";
}

<div class="hero">
    <div class="hero-logo-wrap">
        <img src="/images/monero-symbol-on-white-480.png" alt="Monero" class="hero-logo" />
    </div>
    <h1>The <span>Privacy Hypocrite</span> Shame List</h1>
    <p>Companies that market themselves as privacy-focused but refuse to accept Monero — the only truly private money.</p>
    <a href="/Submit" class="btn btn-primary">Submit a Company</a>
</div>

<div class="sort-bar">
    <span>Sort by:</span>
    <a href="?sort=date" class="@(Model.Sort == "date" ? "active" : "")">Date Added</a>
    <a href="?sort=name" class="@(Model.Sort == "name" ? "active" : "")">Name (A–Z)</a>
</div>

<p class="entry-count"><strong>@Model.Entries.Count</strong> @(Model.Entries.Count == 1 ? "company" : "companies") currently listed</p>

@if (Model.Entries.Count == 0)
{
    <div class="empty-state">
        <div class="big-icon">🏆</div>
        <p>No entries yet. Know a privacy hypocrite? <a href="/Submit">Submit them.</a></p>
    </div>
}
else
{
    <div class="shame-list">
        @foreach (var e in Model.Entries)
        {
            var badgeClass = e.Category switch
            {
                ShameCategory.DelistedXmr => "shame-badge shame-badge-delisted",
                ShameCategory.AllowsOtherCrypto => "shame-badge shame-badge-other",
                ShameCategory.Scammer => "shame-badge shame-badge-scammer",
                _ => "shame-badge"
            };
            var badgeText = e.Category switch
            {
                ShameCategory.DelistedXmr => "Delisted XMR",
                ShameCategory.AllowsOtherCrypto => "Other Crypto Only",
                ShameCategory.Scammer => "Scammer",
                _ => "Never Added XMR"
            };

            <div class="shame-card">
                <div class="shame-card-header">
                    <div>
                        <div class="company-name">
                            <a href="/company/@e.Slug" style="color:var(--text);text-decoration:none">@e.Name</a>
                        </div>
                        <a href="@e.Website" target="_blank" rel="noopener nofollow" class="company-website">@e.Website</a>
                    </div>
                    <span class="@badgeClass">@badgeText</span>
                </div>
                <div class="shame-description">@TextHelpers.Linkify(e.Description)</div>
                <div class="shame-why"><strong>Why shamed:</strong> @TextHelpers.Linkify(e.WhyShamed)</div>

                @if (!string.IsNullOrWhiteSpace(e.AdminComment))
                {
                    <div class="admin-comment"><strong>📌 Note:</strong> @TextHelpers.Linkify(e.AdminComment)</div>
                }
                @if (!string.IsNullOrWhiteSpace(e.MoneroAlternativeUrl))
                {
                    <div class="alternative-box">
                        <strong>✅ Monero alternative:</strong>
                        <a href="@e.MoneroAlternativeUrl" target="_blank" rel="noopener nofollow">@e.MoneroAlternativeUrl</a>
                    </div>
                }

                <div class="shame-card-footer">
                    @if (!string.IsNullOrWhiteSpace(e.ContactUrl))
                    {
                        <a href="@e.ContactUrl" target="_blank" rel="noopener nofollow" class="contact-link">📬 Tell them to add Monero</a>
                    }
                    else
                    {
                        <span></span>
                    }
                    <span class="date-added">Added @e.DateAdded.ToString("MMM d, yyyy")</span>
                </div>
            </div>
        }
    </div>
}

@if (Model.Converted.Count > 0)
{
    <div class="converted-section">
        <p class="converted-heading">
            ✅ <strong>@Model.Converted.Count</strong> @(Model.Converted.Count == 1 ? "company" : "companies") that were shamed and now accept Monero:
            @for (var ci = 0; ci < Model.Converted.Count; ci++)
            {
                var c = Model.Converted[ci];
                <a href="/company/@c.Slug" class="converted-link">@c.Name</a>
                @(ci < Model.Converted.Count - 1 ? ", " : "")
            }
        </p>
    </div>
}