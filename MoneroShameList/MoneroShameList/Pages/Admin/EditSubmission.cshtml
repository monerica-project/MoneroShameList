@page
@using MoneroShameList.Models
@model MoneroShameList.Pages.Admin.EditSubmissionModel
@{
    ViewData["Title"] = "Admin — Edit Submission";
}

<div style="margin-bottom:1.25rem">
    <a href="/Admin" class="btn btn-ghost btn-sm">← Back to Submissions</a>
</div>

<div class="form-card">
    <div class="form-title">Edit Submission</div>
    <div class="form-subtitle">Update the submission details or change its status.</div>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>
        <input type="hidden" asp-for="Input.Id" />

        <div class="form-group">
            <label asp-for="Input.Status">Status *</label>
            <select asp-for="Input.Status">
                <option value="Pending">Pending</option>
                <option value="Approved">Approved</option>
                <option value="Rejected">Rejected</option>
            </select>
        </div>

        <div class="form-group">
            <label asp-for="Input.Name">Company Name *</label>
            <input asp-for="Input.Name" type="text" />
            <span asp-validation-for="Input.Name" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Website">Website *</label>
            <input asp-for="Input.Website" type="text" />
            <span asp-validation-for="Input.Website" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.Category">Category *</label>
            <select asp-for="Input.Category">
                <option value="NeverAdded">Never Added XMR</option>
                <option value="DelistedXmr">Delisted XMR</option>
                <option value="AllowsOtherCrypto">Allows Other Crypto Only</option>
                <option value="Converted">Converted (Now Accepts XMR)</option>
                <option value="@ShameCategory.MixedSupport">Mixed Support</option>
                <option value="Scammer">Scammer</option>
            </select>
        </div>

        <div class="form-group">
            <label asp-for="Input.Description">Description *</label>
            <textarea asp-for="Input.Description"></textarea>
            <span asp-validation-for="Input.Description" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.WhyShamed">Why Shamed *</label>
            <textarea asp-for="Input.WhyShamed"></textarea>
            <span asp-validation-for="Input.WhyShamed" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.ContactUrl">Contact URL</label>
            <input asp-for="Input.ContactUrl" type="text" />
            <span asp-validation-for="Input.ContactUrl" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.MoneroAlternativeUrl">Monero Alternative URL</label>
            <input asp-for="Input.MoneroAlternativeUrl" type="text" />
            <span asp-validation-for="Input.MoneroAlternativeUrl" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Input.AdminNote">Admin Note</label>
            <textarea asp-for="Input.AdminNote" placeholder="Internal note — not shown publicly"></textarea>
        </div>

        <div class="form-group">
            <label asp-for="Input.SubmitterEmail">Submitter Email</label>
            <input asp-for="Input.SubmitterEmail" type="email" />
            <span asp-validation-for="Input.SubmitterEmail" class="field-error"></span>
        </div>

        <div style="display:flex;gap:0.75rem">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a href="/Admin" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
