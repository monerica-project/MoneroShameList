@page "/company/{slug}"
@using MoneroShameList.Helpers
@using MoneroShameList.Models
@model MoneroShameList.Pages.Company.DetailModel
@{
    ViewData["Title"] = Model.Entry.Name;

    var badgeClass = Model.Entry.Category switch
    {
        ShameCategory.DelistedXmr => "shame-badge shame-badge-delisted",
        ShameCategory.AllowsOtherCrypto => "shame-badge shame-badge-other",
        ShameCategory.Converted => "shame-badge shame-badge-converted",
        ShameCategory.MixedSupport => "shame-badge shame-badge-mixed",
        ShameCategory.Scammer => "shame-badge shame-badge-scammer",
        _ => "shame-badge"
    };
    var badgeText = Model.Entry.Category switch
    {
        ShameCategory.DelistedXmr => "Delisted XMR",
        ShameCategory.AllowsOtherCrypto => "Other Crypto Only",
        ShameCategory.Converted => "Now Accepts XMR",
        ShameCategory.MixedSupport => "Mixed Support",
        ShameCategory.Scammer => "Scammer",
        _ => "Never Added XMR"
    };

    var backUrl = Model.Entry.Category switch
    {
        ShameCategory.Converted => "/?tab=converted",
        ShameCategory.MixedSupport => "/?tab=mixed",
        _ => "/"
    };
}

<div style="margin-bottom:1.25rem">
    <a href="@backUrl" class="btn btn-ghost btn-sm">← Back to the List</a>
</div>

<div class="shame-card" style="max-width:800px">
    <div class="shame-card-header">
        <div>
            <div class="company-name" style="font-size:1.4rem">@Model.Entry.Name</div>
            <a href="@Model.Entry.Website" target="_blank" rel="noopener nofollow" class="company-website">@Model.Entry.Website</a>
        </div>
        <span class="@badgeClass">@badgeText</span>
    </div>

    <div class="shame-description">@TextHelpers.Linkify(Model.Entry.Description)</div>

    @if (Model.Entry.Category != ShameCategory.Converted)
    {
        <div class="shame-why"><strong>Why shamed:</strong> @TextHelpers.Linkify(Model.Entry.WhyShamed)</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Entry.AdminComment))
    {
        <div class="admin-comment"><strong>📌 Note:</strong> @TextHelpers.Linkify(Model.Entry.AdminComment)</div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.Entry.MoneroAlternativeUrl))
    {
        <div class="alternative-box">
            <strong>✅ Monero alternative:</strong>
            <a href="@Model.Entry.MoneroAlternativeUrl" target="_blank" rel="noopener nofollow">@Model.Entry.MoneroAlternativeUrl</a>
        </div>
    }

    <div class="shame-card-footer">
        @if (Model.Entry.Category != ShameCategory.Converted && !string.IsNullOrWhiteSpace(Model.Entry.ContactUrl))
        {
            <a href="@Model.Entry.ContactUrl" target="_blank" rel="noopener nofollow" class="contact-link">📬 Tell them to add Monero</a>
        }
        else
        {
            <span></span>
        }
        <span class="date-added">Added @Model.Entry.DateAdded.ToString("MMM d, yyyy")</span>
    </div>
</div>